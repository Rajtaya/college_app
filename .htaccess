Options -Indexes
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Block direct access to sensitive files
RewriteRule ^api/config/         - [F,L]
RewriteRule ^api/cron/           - [F,L]
RewriteRule ^api/helpers/        - [F,L]
RewriteRule ^api/middleware/     - [F,L]
RewriteRule ^api/models/         - [F,L]

# Route all /api/v1/* requests to api/index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^api/v1/(.*)$ api/index.php [QSA,L]

# Block direct access to uploads (serve via /api/v1/file/...)
<IfModule mod_rewrite.c>
  RewriteRule ^uploads/(.*)$  - [F,L]
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set X-XSS-Protection         "1; mode=block"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Permissions-Policy        "geolocation=(), microphone=(), camera=()"
</IfModule>

# PHP settings
<IfModule mod_php8.c>
  php_value upload_max_filesize  20M
  php_value post_max_size        25M
  php_value max_execution_time   120
  php_value memory_limit         256M
</IfModule>
